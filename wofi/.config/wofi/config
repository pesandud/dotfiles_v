# mode & placement
show=drun
location=top
width=700
lines=8
columns=2
dynamic_lines=false

# icons
allow_images=true
image_size=36

# search & UX
matching=fuzzy
insensitive=true
hide_scroll=false
prompt=

# terminal
term=foot

# keybinds (vim-ish)
key_up=Control_L-p
key_down=Control_L-n
key_left=Ctrl-h
key_right=Ctrl-l
key_submit=Return
key_forward=Tab
key_backward=Shift-ISO_Left_Tab

# stylesheet
style=/home/cat/.config/wofi/style.css
