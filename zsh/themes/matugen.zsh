# Matugen generated syntax highlighting colors

# This line ensures Zsh treats this as a Map/Dictionary
typeset -A ZSH_HIGHLIGHT_STYLES

# Valid commands, aliases, and functions
ZSH_HIGHLIGHT_STYLES[command]='fg=#ffb595'
ZSH_HIGHLIGHT_STYLES[alias]='fg=#e6bead'
ZSH_HIGHLIGHT_STYLES[builtin]='fg=#ffb595'
ZSH_HIGHLIGHT_STYLES[function]='fg=#e6bead'

# Invalid/Error tokens
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=#ffb4ab'

# Strings and Paths
ZSH_HIGHLIGHT_STYLES[string]='fg=#d2c78f'
ZSH_HIGHLIGHT_STYLES[path]='fg=#c6c6c6,underline'

# Comments
ZSH_HIGHLIGHT_STYLES[comment]='fg=#919191'

# Brackets & Operators
ZSH_HIGHLIGHT_STYLES[bracket]='fg=#c6c6c6'
